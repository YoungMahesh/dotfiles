[
  {
    "bindings": {
      // disable recording by q in vim
      "q": null,
      "ctrl-j": "workspace::ToggleLeftDock",
      // "ctrl-k": "workspace::ToggleBottomDock",
      "ctrl-k": "terminal_panel::Toggle",
      "ctrl-;": "workspace::ToggleRightDock",
      "ctrl-m": "editor::ToggleFocus",
      "ctrl-l": "command_palette::Toggle",
      "ctrl-a": "editor::SelectAll",
      "ctrl-e": "project_panel::ToggleFocus",
      "ctrl-g": "git_panel::ToggleFocus",
      "ctrl-p": "file_finder::Toggle",
      "ctrl-o": "outline_panel::ToggleFocus",
    },
  },
  {
    "context": "OutlinePanel && not_editing",
    "bindings": {
      "z c": "outline_panel::CollapseSelectedEntry",
      "z o": "outline_panel::ExpandSelectedEntry",
    },
  },
  {
    "context": "Terminal",
    "bindings": {
      "ctrl-p": null,
      "ctrl-n": null,
      "ctrl-a": null,
      "ctrl-l": null,
      "ctrl-e": null,
      "ctrl-shift-n": "workspace::NewTerminal",
      // default:
      //  "ctrl-shift": switch terminal
      //  ctrl-c: stop process
    },
  },
  {
    "context": "vim_mode == normal",
    "bindings": {},
  },
  {
    "context": "(vim_mode == normal && Editor)",
    "bindings": {
      "q": "vim::InsertEndOfLine",
      "r": "vim::Redo",
      "s s": "workspace::SaveAll",
      "space f f": "editor::Format",
      "g r": "editor::FindAllReferences", // goto references

      "g o": "editor::ExpandAllDiffHunks",
      "g c": "editor::CollapseAllDiffHunks",
      "g s": "git::StageAndNext",
      "g u": "git::UnstageAndNext",

      // panel == popup-windows (e.g. settings window)
      // pane == current file/tab
      "t ;": "pane::CloseActiveItem",
      "t l": "pane::SwapItemLeft",
      "t r": "pane::SwapItemRight",
      "t p": "pane::ActivatePreviousItem",
      "t n": "pane::ActivateNextItem",
      "t 0": "workspace::ActivatePaneLeft",
      "t 9": "workspace::ActivatePaneRight",
      "t s": "pane::SplitVertical",
      "t t": "pane::TogglePinTab",
      "t q": [
        "pane::CloseOtherItems",
        {
          "close_pinned": false,
        },
      ],
    },
  },
  {
    "context": "(vim_mode == normal || vim_mode == visual)",
    "bindings": {
      "a": "vim::ScrollUp",
      ";": "vim::ScrollDown",
      "'": "vim::EndOfLine",
    },
  },
  {
    "context": "vim_mode == insert",
    "bindings": {
      "ctrl-v": "editor::Paste",
    },
  },
  {
    "context": "(ProjectPanel && not_editing)",
    "bindings": {
      // enter: toggle fold/unfold directory; k: move up; j: move down
      "o": "project_panel::NewFile",
      "d d": "project_panel::Delete",
      "f": "project_panel::RevealInFileManager",
      "i": "project_panel::Rename",
      "y y": "project_panel::Copy",
      "p": "project_panel::Paste",
    },
  },
  {
    "context": "(Terminal || AgentPanel || (Editor && mode == full) )",
    "bindings": {
      "ctrl-s": "agent::AddSelectionToThread",
    },
  },
]
