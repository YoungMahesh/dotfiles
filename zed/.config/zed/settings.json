// documentation: https://zed.dev/docs/configuring-zed
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the command palette
{
  "$schema": "zed://schemas/settings",
  "context_servers": {
    "mcp-server-exa-search": {
      "enabled": true,
      "remote": false,
      "settings": {
        "exa_api_key": null,
      },
    },
  },
  "format_on_save": "off",
  "cli_default_open_behavior": "new_window",
  "project_panel": {
    "dock": "left",
  },
  "outline_panel": {
    "dock": "left",
  },
  "collaboration_panel": {
    "dock": "left",
  },
  "git_panel": {
    "dock": "left",
  },
  "diff_view_style": "unified",
  "edit_predictions": {
    "provider": "none",
  },
  "tabs": {
    "file_icons": true,
    "git_status": true,
  },
  "title_bar": {
    "show_menus": false,
  },
  "show_edit_predictions": false,
  "agent_buffer_font_size": 18.0,
  "agent_ui_font_size": 24.0,
  "ui_font_weight": 400.0,
  "relative_line_numbers": "enabled",
  "git": {
    "inline_blame": {
      "enabled": false,
    },
  },
  "language_models": {
    "opencode": {
      "show_free_models": false,
      "show_zen_models": false,
    },
    "openai_compatible": {
      "General Compute": {
        "api_url": "https://api.generalcompute.com/v1",
        "available_models": [
          {
            "name": "minimax-m2.7",
            "max_tokens": 200000,
            "max_output_tokens": 32000,
            "max_completion_tokens": 200000,
            "capabilities": {
              "tools": true,
              "images": true,
              "parallel_tool_calls": true,
              "prompt_cache_key": true,
              "chat_completions": true,
              "interleaved_reasoning": false,
            },
          },
        ],
      },
      "MiniMax": {
        "api_url": "https://api.minimax.io/v1",
        "available_models": [
          {
            "name": "MiniMax-M2.7",
            "max_tokens": 200000,
            "max_output_tokens": 32000,
            "max_completion_tokens": 200000,
            "capabilities": {
              "tools": true,
              "images": true,
              "parallel_tool_calls": true,
              "prompt_cache_key": true,
              "chat_completions": true,
            },
          },
        ],
      },
    },
    "open_router": {
      "available_models": [
        {
          "name": "x-ai/grok-code-fast-1",
          // input-price: $0.2/M, output-price: $1.5/M
          "display_name": "Grok code 0.2/1.5",
          // max_tokens: maximum output tokens per response
          "max_tokens": 256000,
          "supports_tools": true,
          "provider": {
            "data_collection": "disallow",
          },
        },
        {
          "name": "deepseek/deepseek-v3.2",
          "display_name": "Deepseek-3.2 0.27/.40",
          "max_tokens": 163800,
          "supports_tools": true,
          "provider": {
            "data_collection": "disallow",
          },
        },
        {
          "name": "anthropic/claude-opus-4.5",
          "display_name": "Claude Opus-4.5 5/25",
          "max_tokens": 64000,
          "supports_tools": true,
          "provider": {
            "data_collection": "disallow",
          },
        },
        {
          "name": "anthropic/claude-haiku-4.5",
          "display_name": "Claude Haiku-4.5 1/5",
          "max_tokens": 64000,
          "supports_tools": true,
          "provider": {
            "data_collection": "disallow",
          },
        },
        {
          "name": "nex-agi/deepseek-v3.1-nex-n1:free",
          "display_name": "free:Deepseek-3.1 nex-n1",
          "max_tokens": 163800,
          "supports_tools": true,
          "provider": {
            // "data_collection": "deny",
            //    if used deny, zed-editor gives warning: Value is not accepted. Valid values: "allow", "disallow". (1)
            //    if used 'disallow', openrouter API gives error: Invalid option: expected one of "deny"|"allow"
          },
        },
        {
          "name": "xiaomi/mimo-v2-flash:free",
          "display_name": "Xiaomi Mimo-2:free",
          "max_tokens": 100000,
          "supports_tools": true,
          "provider": {
            "data_collection": "disallow",
          },
        },
        {
          "name": "kwaipilot/kat-coder-pro:free",
          "display_name": "Kat Coder pro:free",
          "max_tokens": 100000,
          "supports_tools": true,
          "provider": {
            "data_collection": "disallow",
          },
        },
      ],
    },
  },
  "agent": {
    "sandbox_permissions": {
      "network_hosts": ["zed.dev"],
    },
    "profiles": {
      "ask": {
        "name": "Ask",
        "tools": {
          "create_thread": true,
          "diagnostics": true,
          "fetch": true,
          "list_agents_and_models": true,
          "list_directory": true,
          "find_path": true,
          "find_references": true,
          "get_code_actions": true,
          "go_to_definition": true,
          "read_file": true,
          "grep": true,
          "skill": true,
          "spawn_agent": true,
          "search_web": true,
        },
        "enable_all_context_servers": false,
        "context_servers": {
          "mcp-server-exa-search": {
            "tools": {
              "web_fetch_exa": true,
              "web_search_exa": true,
            },
          },
        },
      },
    },
    "tool_permissions": {
      "tools": {
        // https://zed.dev/docs/ai/tool-permissions#mcp-tools
        "terminal": {
          "always_allow": [
            { "pattern": "pnpm\\s+run\\s+typecheck" },
            { "pattern": "pnpm\\s+run\\s+lint" },
          ],
        },
        "fetch": {
          // from observation, i found - "sandbox_permissions"."network_hosts" working instead of this
          "always_allow": [{ "pattern": "^https://zed\\.dev" }],
        },
        "mcp:mcp-server-exa-search:web_fetch_exa": {
          "default": "allow",
        },
        "mcp:mcp-server-exa-search:web_search_exa": {
          "default": "allow",
        },
      },
    },
    "inline_assistant_model": {
      "provider": "opencode",
      "model": "go/deepseek-v4-flash",
      "enable_thinking": true,
    },
    "dock": "right",
    "favorite_models": [
      {
        "provider": "openrouter",
        "model": "openrouter/free",
        "enable_thinking": false,
      },
    ],
    "default_model": {
      "effort": "xhigh",
      "enable_thinking": true,
      "provider": "opencode",
      "model": "go/deepseek-v4-flash",
    },
    "default_profile": "ask",
    "model_parameters": [],
  },
  "autosave": "on_focus_change",
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },
  "vim_mode": true,
  "icon_theme": {
    "mode": "light",
    "light": "Catppuccin Latte",
    "dark": "Catppuccin Latte",
  },
  // above 22 this top and bottom part of popup window (e.g. settings window) get cutoff
  //    from the screen, you cannot see the borders of window, cannot access some options
  "ui_font_size": 22.0,
  "buffer_font_size": 22.0,
  "theme": {
    "mode": "dark",
    "light": "Gruvbox Light Hard",
    //"dark": "One Dark"
    // problems with "Github Dark default":
    //    does not have distinct background-color for tab which makes it difficult to recognize current tab from the topbar tab-list
    "dark": "GitHub Dark Default",
  },
  // Settings related to preview tabs.
  "preview_tabs": {
    // Whether preview tabs should be enabled.
    // Preview tabs allow you to open files in preview mode, where they close automatically
    // when you switch to another file unless you explicitly pin them.
    // This is useful for quickly viewing files without cluttering your workspace.
    "enabled": false,
    // Whether to open tabs in preview mode when selected from the file finder.
    "enable_preview_from_file_finder": false,
    // Whether a preview tab gets replaced when code navigation is used to navigate away from the tab.
    "enable_keep_preview_on_code_navigation": false,
  },
  "languages": {
    "YAML": {
      "tab_size": 2,
    },
    //   "TypeScript": {
    //     "formatter": {
    //       "external": {
    //         // "command": "npx prettier",
    //         "command": "node_modules/.bin/prettier",
    //         "arguments": ["--stdin-filepath", "{buffer_path}"]
    //       }
    //     }
    //   }
  },
}
